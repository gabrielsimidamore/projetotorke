      }
    },
    {
      "parameters": {
        "model": "dall-e-3",
        "prompt": "=Professional LinkedIn post image for automotive parts business. {{ $json.descricao_imagem }}. Style: clean, corporate, modern. No text overlay. Aspect ratio 1:1.",
        "size": "1024x1024",
        "quality": "standard",
        "responseFormat": "url"
      },
      "id": "dall-e-gerar-imagem",
      "name": "DALL-E — Gerar Imagem",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.4,
      "position": [1780, 480],
      "credentials": {
        "openAiApi": {
          "id": "openai-key",
          "name": "OpenAI"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Combinar dados: post gerado + url_imagem (da ideia ou gerada pelo DALL-E)\nconst post = $input.first().json;\nconst imagemUrl = post.tem_imagem\n  ? $('Buscar URL Imagem da Ideia').first()?.json?.imagem_url || null\n  : $('DALL-E — Gerar Imagem').first()?.json?.data?.[0]?.url || null;\n\nreturn [{\n  json: {\n    ideia_id:        post.ideia_id,\n    plataforma:      'LinkedIn',\n    conteudo_gerado: post.conteudo_gerado,\n    hashtags:        post.hashtags,\n    url_imagem:      imagemUrl,\n    status:          'Em andamento',\n  }\n}];"
      },
