              "keyName": "id",
              "keyValue": "={{ $json.ideia_id }}",
              "condition": "eq"
            }
          ]
        }
      },
      "id": "get-ideia-image-url",
      "name": "Buscar URL Imagem da Ideia",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1780, 260],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-crm",
